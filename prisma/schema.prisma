// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//*************************************************************
// --------------- GERENCIAMENTO DE USUÁRIOS-------------------
//*************************************************************
model Imob {
  id                     String                  @id @default(uuid())
  orgId                  String                  @unique
  razaoSocial            String?
  nomeFantasia           String?
  cnpj                   String?
  telefone               String?
  emailContato           String?
  logoUrl                String?
  creci                  String?
  representanteNome      String?
  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  cidade                 String?
  uf                     String?
  users                  Users[]
  imovels                Imovel[]
  contratoImovelLocacaos ContratoImovelLocacao[]
  configuracaoInter      ConfiguracaoInter?

  @@map("imob")
}

model Users {
  id        String    @id // vai ser o mesmo do clerk
  email     String
  firstName String
  lastName  String
  creci     String?
  role      UsersRole
  ativo     Boolean   @default(true)

  imobId               String
  imob                 Imob                  @relation(fields: [imobId], references: [id], onDelete: Cascade)
  operadorVistorias    Vistoria[]            @relation(name: "VistoriaOperador")
  vistoriadorVistorias Vistoria[]            @relation(name: "VistoriaVistoriador")
  transacoes           TransacaoFinanceira[]
  comissoes            Comissao[]

  @@map("users")
}

enum UsersRole {
  OPERADOR
  CORRETOR
  ADMIN
}

//*************************************************************
// --------------- GERENCIAMENTO DE IMÓVEIS--------------------
//*************************************************************

model Imovel {
  id              String     @id @default(uuid())
  codigo          String     @unique
  numero          Int
  bairro          String
  cidade          String
  uf              String
  cep             Int
  latitude        Float?
  longitude       Float?
  tipo            TipoImovel @default(CASA)
  forVenda        Boolean    @default(false)
  forLocacao      Boolean    @default(false)
  valorAluguel    Int?
  valorCondominio Int?
  valorIPTU       Int?
  valorVenda      Int?
  valorTotal      Int?
  area            Int        @default(0)

  titulo    String   @default("")
  descricao String?  @db.Text
  imagens   String[] @default([])
  quartos   Int?     @default(0)
  banheiros Int?     @default(0)
  vagas     Int?     @default(0)
  publicado Boolean  @default(false)

  loteamentoId String?
  loteamento   Loteamento? @relation(fields: [loteamentoId], references: [id], onDelete: Cascade)
  quadra       String?
  loteNumero   String?
  topografia   String?
  statusLote   StatusLote? @default(DISPONIVEL)

  aluguelDados Json?

  imobId                 String
  imob                   Imob                    @relation(fields: [imobId], references: [id], onDelete: Cascade)
  imovelLocacaos         ImovelLocacao[]
  imovelVendas           ImovelVenda[]
  vistorias              Vistoria[]
  contratoImovelLocacaos ContratoImovelLocacao[]
  transacoes             TransacaoFinanceira[]

  @@map("imovel")
}

//*************************************************************
model ImovelLocacao {
  id            String   @id @default(uuid())
  dataInicio    DateTime
  valorAluguel  Float?
  dataFim       DateTime
  hasCondominio Boolean
  hasIPTU       Boolean
  valorTotal    Float

  taxaAdministracao    Float? // Taxa de administração (ex: 10.00)
  taxaMultasEncargos   Float? // Taxa sobre multas e encargos (ex: 50.00)
  taxaIntermediacao    Float? // Taxa de intermediação (ex: 100.00)
  irrfResponsabilidade String? // "LOCADOR" ou "LOCATARIO"
  carenciaRepasse      Int? // Carência para repasse do aluguel (ex: 10)

  // Relação com múltiplos períodos vigentes e históricos
  periodos PeriodoContratoLocacao[]

  // --- REAJUSTE ---
  proximoReajuste       DateTime?
  periodicidadeReajuste Int? // Salva em meses. Ex: 12
  indiceReajuste        String? // Ex: "IGPM", "IPCA", "INPC"

  // --- QUEBRA DE CONTRATO ---
  multaQuebraContrato Float? // Valor ou percentual (ex: 8.33)
  tipoMultaQuebra     String? // "PERCENTUAL", "MESES" ou "VALOR"
  vencimentoQuebra    DateTime? // "Quebra do contrato vence em"

  // --- PONTUALIDADE (Mantido opcional na tabela pai) ---
  descontoPontualidade Float? // Ex: 5.11
  tipoDesconto         String? // "PERCENTUAL" ou "VALOR"
  diasAntecedenciaDesc Int? // "Até quantos dias antes" (Ex: 12)

  // --- MULTA E JUROS (Mantido opcional na tabela pai) ---
  multaAtrasoPercentual  Float? // Ex: 2.00
  diasCarenciaMulta      Int? // "Cobrar após X dias" (Ex: 1)
  jurosAtrasoPercentual  Float? // Juros mensal pro rata (Ex: 1.00)
  diasCarenciaJuros      Int? // "Cobrar após X dias" (Ex: 1)
  imovelId               String
  imovel                 Imovel                  @relation(fields: [imovelId], references: [id], onDelete: Cascade)
  locadors               Locador[]
  contratoImovelLocacaos ContratoImovelLocacao[]

  @@map("imovel_locacao")
}

model PeriodoContratoLocacao {
  id              String        @id @default(uuid())
  imovelLocacaoId String
  imovelLocacao   ImovelLocacao @relation(fields: [imovelLocacaoId], references: [id], onDelete: Cascade)

  dataInicio DateTime
  dataFim    DateTime // Fim do período (ex: De 27/08/2024 a 26/08/2025)

  valorAluguel    Float
  hasCondominio   Boolean @default(false)
  valorCondominio Float?
  hasIPTU         Boolean @default(false)
  valorIPTU       Float?
  valorTotal      Float

  descontoPontualidade Float?
  tipoDesconto         String? // "PERCENTUAL" ou "VALOR"
  diasAntecedenciaDesc Int?

  multaAtrasoPercentual Float?
  diasCarenciaMulta     Int?
  jurosAtrasoPercentual Float?
  diasCarenciaJuros     Int?
  indiceReajuste        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("periodo_contrato_locacao")
}

model Locador {
  id            String @id @default(uuid())
  nome          String
  cpfCnpj       String
  telefone      Json? // {objeto com telefone, qualificacao e observacao}
  email         String
  endereco      Json? // {objeto com cep, logradouro, numero, complemento, bairro, municipio, estado.}
  dataNasc      String
  rg            String
  orgaoEmissor  String
  estadoCivil   String
  profissao     String
  nacionalidade String
  genero        String

  documentoUrl    Json? // objeto com lista de urls (documentos feitos uploads com url e nome do documentos)
  imovelLocacaoId String?
  imovelLocacao   ImovelLocacao? @relation(fields: [imovelLocacaoId], references: [id], onDelete: Cascade)
}

model ContratoImovelLocacao {
  id              String  @id @default(uuid())
  imovelLocacaoId String?

  imovelLocacao ImovelLocacao? @relation(fields: [imovelLocacaoId], references: [id], onDelete: Cascade)
  imovelId      String
  imovel        Imovel         @relation(fields: [imovelId], references: [id], onDelete: Cascade)

  imobId               String
  imob                 Imob                  @relation(fields: [imobId], references: [id], onDelete: Cascade)
  fiadors              Fiador[]
  locatarios           Locatario[]
  transacaoFinanceiras TransacaoFinanceira[]
  documentoUrl         Json?

  @@map("contrato_imovel_locacao")
}

model Fiador {
  id            String @id @default(uuid())
  nome          String
  cpfCnpj       String
  telefone      Json? // {objeto com telefone, qualificacao e observacao}
  email         String
  endereco      Json? // {objeto com cep, logradouro, numero, complemento, bairro, municipio, estado.}
  dataNasc      String
  rg            String
  orgaoEmissor  String
  estadoCivil   String
  profissao     String
  nacionalidade String
  genero        String

  documentoUrl Json? // objeto com lista de urls (documentos feitos uploads com url e nome do documentos)
  contratoId   String
  contrato     ContratoImovelLocacao @relation(fields: [contratoId], references: [id], onDelete: Cascade)
}

model Locatario {
  id            String  @id @default(uuid())
  nome          String
  cpfCnpj       String
  telefone      Json? // [{ tipo: string, numero: string, observacao?: string }]
  email         String
  endereco      Json? // { cep, logradouro, numero, complemento, bairro, municipio, estado }
  dataNasc      String
  rg            String
  orgaoEmissor  String
  estadoCivil   String
  profissao     String
  nacionalidade String
  genero        String
  rendaMensal   Float?
  rne           String?

  // Dados do Cônjuge
  conjugeNome          String?
  conjugeCpf           String?
  conjugeRg            String?
  conjugeOrgaoEmissor  String?
  conjugeEmail         String?
  conjugeDataNasc      String?
  conjugeProfissao     String?
  conjugeRendaMensal   Float?
  conjugeNacionalidade String?
  conjugeRne           String?
  conjugeTelefone      Json? // [{ tipo: string, numero: string, observacao?: string }]

  documentoUrl Json? // Objeto/lista JSON mapeando documentos digitalizados por categoria/nome
  contratoId   String?
  contrato     ContratoImovelLocacao? @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  vistorias    Vistoria[]
}

//*************************************************************
// --------------- VENDAS --------------------
//*************************************************************

model ImovelVenda {
  id         String   @id @default(uuid())
  dataInicio DateTime
  dataFim    DateTime

  imovelId String
  imovel   Imovel @relation(fields: [imovelId], references: [id], onDelete: Cascade)

  @@map("imovel_venda")
}

model Loteamento {
  id              String   @id @default(uuid())
  nome            String
  slug            String   @unique
  cidade          String
  uf              String
  descricao       String   @db.Text
  imagens         Json?
  infraestrutura  Json?
  coordenadasSvg  Json?
  dadosCondominio Json?
  lotes           Imovel[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("loteamento")
}

enum StatusLote {
  DISPONIVEL
  RESERVADO
  VENDIDO
}

model Lead {
  id            String     @id @default(uuid())
  nome          String
  telefone      String
  email         String?
  loteInfo      String? // Ex: "Quadra A - Lote 03 (253m²)"
  valorSimulado Float?
  status        LeadStatus @default(NOVO)
  origem        String     @default("SITE")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Preferências de Interesse para Match de Imóveis
  interesseTipo      TipoImovel?
  interesseNegocio   String? // 'VENDA', 'LOCACAO' ou 'AMBOS'
  interessePrecoMin  Float?
  interessePrecoMax  Float?
  interesseQuartos   Int?
  interesseBanheiros Int?
  interesseVagas     Int?
  interesseBairros   String?

  // Automação de E-mail
  envioAutomatico Boolean   @default(false)
  ultimoEnvioAuto DateTime?

  @@map("lead")
}

enum LeadStatus {
  NOVO
  EM_ATENDIMENTO
  VISITA_AGENDADA
  FECHADO
  PERDIDO
}

//*************************************************************
// --------------- VISTORIA --------------------
//*************************************************************

model Vistoria {
  id          String       @id @default(uuid())
  codigo      String
  data        DateTime
  tipo        TipoVistoria
  observacoes String       @db.Text // Aba "OBSERVAÇÕES" (já existente)
  assinatura  String? // Aba "INFORMAÇÕES"

  operadorId String
  operador   Users  @relation(name: "VistoriaOperador", fields: [operadorId], references: [id])

  vistoriadorId String
  vistoriador   Users  @relation(name: "VistoriaVistoriador", fields: [vistoriadorId], references: [id])

  imovelId String
  imovel   Imovel @relation(fields: [imovelId], references: [id], onDelete: Cascade)

  tipoImovelVistoriado TipoImovelVistoriado
  status               VistoriaStatus
  ambienteVistorias    AmbienteVistoria[]
  comentariosVistoria  ComentarioVistoria[]

  // ==========================================
  // METADADOS DO PROPRIETÁRIO
  // ==========================================
  proprietario String?

  // ==========================================
  // ABA: TERMOS GERAIS (JSON)
  // ==========================================
  infoGeral Json?

  // ==========================================
  // ABA: CHAVES (Simplificado)
  // ==========================================
  chavesQuantidade Int?
  chavesObservacao String? @db.Text // Descrição ex: "3 chaves da porta, 1 do portão"

  // ==========================================
  // ABA: MEDIDORES (Água e Luz)
  // ==========================================
  medidorAguaNumero  String? // Número do relógio da água
  medidorAguaLeitura String? // Leitura atual (consumo)
  medidorAguaFotoUrl String? // Foto do medidor de água

  medidorLuzNumero  String? // Número do relógio da luz
  medidorLuzLeitura String? // Leitura atual (consumo)
  medidorLuzFotoUrl String? // Foto do medidor de luz

  // ==========================================
  // ABA: REPAROS (Simplificado)
  // ==========================================
  reparosNecessarios String? @db.Text // Anotação livre sobre o que precisa arrumar

  // ==========================================
  // ABA: LIMPEZA
  // ==========================================
  limpezaStatus     LimpezaStatus?
  limpezaObservacao String?        @db.Text // Detalhes da limpeza

  // ==========================================
  // ABA: GEOLOCALIZAÇÃO (Para auditoria de presença do vistoriador)
  // ==========================================
  latitude             Float?
  longitude            Float?
  fotoItems            FotoItem[]
  contestacaoVistorias ContestacaoVistoria[]
  tokenAcesso          String?               @unique
  locatarioId          String?
  locatario            Locatario?            @relation(fields: [locatarioId], references: [id], onDelete: SetNull)

  @@map("vistoria")
}

model ContestacaoVistoria {
  id                  String    @id @default(uuid())
  vistoriaId          String
  vistoria            Vistoria  @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)
  ambienteId          String? // Opcional: Se for contestação de um cômodo específico
  ambienteNome        String?
  descricao           String    @db.Text
  midias              Json? // Fotos anexadas pelo inquilino
  createdAt           DateTime  @default(now())
  resolvido           Boolean   @default(false)
  respostaAdmin       String?   @db.Text
  profissionalNome    String?
  profissionalContato String?
  comprovanteUrl      String?
  resolvidoEm         DateTime?
}

// Enum simples para a aba Limpeza
enum LimpezaStatus {
  EXCELENTE
  BOA
  REGULAR
  RUIM
}

enum TipoImovelVistoriado {
  CASA
  APARTAMENTO
}

enum TipoImovel {
  CASA
  CONDOMINIO
  LOTE
  COMERCIAL
  RURAL
  KITNET
}

enum TipoVistoria {
  ENTRADA
  SAIDA
  PERIODICA
}

enum VistoriaStatus {
  NAO_INICIADA
  EM_ANDAMENTO
  AGUARDANDO_APROVACAO
  CONCLUIDA
  CONTESTADA
  CANCELADA
}

model AmbienteVistoria {
  id          String  @id @default(uuid())
  nome        String // Ex: "Fachada", "Quintal", "Sala"
  tipo        String  @default("Outro") // Quarto, Sala, Cozinha, etc.
  ordem       Int     @default(0) // Permite ordenar a lista lateral
  visaoGeral  String? @db.Text
  comentarios String? @db.Text

  vistoriaId String
  vistoria   Vistoria       @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)
  itens      ItemAmbiente[]

  @@map("ambiente_vistoria")
}

// 3. Os Subitens/Componentes de cada Ambiente (Visão Geral, Paredes, Piso, etc.)
model ItemAmbiente {
  id                 String           @id @default(uuid())
  nome               String // Ex: "Visão Geral"
  ordem              Int              @default(0)
  statusVerificacao  ItemStatus       @default(PENDENTE) // Controla o check verde e o X vermelho
  ambienteVistoriaId String
  ambienteVistoria   AmbienteVistoria @relation(fields: [ambienteVistoriaId], references: [id], onDelete: Cascade)
  comentarios        ComentarioItem[]
  fotos              FotoItem[]

  @@map("item_ambiente")
}

// Enum para o status do item (Conforme / Não Conforme)
enum ItemStatus {
  PENDENTE
  CONFORME // Botão verde (check)
  NAO_CONFORME // Botão vermelho (X)
}

// 4. Comentários específicos por Item do Ambiente
model ComentarioItem {
  id             String            @id @default(uuid())
  texto          String            @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  itemAmbienteId String
  itemAmbiente   ItemAmbiente      @relation(fields: [itemAmbienteId], references: [id], onDelete: Cascade)
  midias         MidiaComentario[]

  @@map("comentario_item")
}

model ComentarioVistoria {
  id         String   @id @default(uuid())
  vistoriaId String
  vistoria   Vistoria @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)
  roomId     String // "geral" ou o ID do AmbienteVistoria
  roomName   String
  texto      String   @db.Text
  status     String // "Aprovado" ou "Atenção"
  createdAt  DateTime @default(now())
  midias     Json? // Lista de { url, tipo }

  @@map("comentario_vistoria")
}

// 5. Fotos específicas por Item do Ambiente
model FotoItem {
  id        String   @id @default(uuid())
  url       String
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  // Relaciona a foto a um item de ambiente (comportamento atual)
  itemAmbienteId String?
  itemAmbiente   ItemAmbiente? @relation(fields: [itemAmbienteId], references: [id], onDelete: Cascade)
  // Opcional: Relaciona a foto diretamente à Vistoria (para Medidores/Chaves)
  vistoriaId     String?
  vistoria       Vistoria?     @relation(fields: [vistoriaId], references: [id], onDelete: Cascade)

  @@map("foto_item")
}

model MidiaComentario {
  id           String         @id @default(uuid())
  url          String
  tipo         TipoMidia      @default(FOTO)
  ordem        Int            @default(0)
  createdAt    DateTime       @default(now())
  comentarioId String
  comentario   ComentarioItem @relation(fields: [comentarioId], references: [id], onDelete: Cascade)

  @@map("midia_comentario")
}

enum TipoMidia {
  FOTO
  VIDEO
}

model ContractTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String // 'LOCACAO' | 'VENDA' | 'LIMPEZA' | 'PROPOSTA'
  fileName  String // Nome do arquivo gerado em public/templates-docx/[uuid].docx
  content   String   @db.Text // Texto simples extraído do docx para pré-visualização
  variables String[] @default([]) // Array de variáveis detectadas ex: ["nome_inquilino", "cpf"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contract_template")
}

//*************************************************************
// --------------- FINANCEIRO --------------------
//*************************************************************

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum CategoriaTransacao {
  ALUGUEL
  REPASSE
  TAXA_ADM
  COMISSAO
  CUSTO_OPERACIONAL
  OUTRO
}

enum StatusTransacao {
  PENDENTE
  LIQUIDADO
  CANCELADO
}

model TransacaoFinanceira {
  id             String             @id @default(uuid())
  descricao      String
  valor          Float
  tipo           TipoTransacao
  categoria      CategoriaTransacao
  status         StatusTransacao    @default(PENDENTE)
  dataVencimento DateTime
  dataPagamento  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  metadata       Json?

  // Relacionamentos opcionais
  imovelId   String?
  imovel     Imovel?                @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  usuarioId  String?
  usuario    Users?                 @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  contratoId String?
  contrato   ContratoImovelLocacao? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  // Vínculos
  comissao     Comissao[]
  conciliacoes MovimentacaoBancaria[]

  // Garante que cada cobrança de aluguel gere no máximo um repasse.
  transacaoOrigemId String?               @unique
  transacaoOrigem   TransacaoFinanceira?  @relation("RepasseOrigem", fields: [transacaoOrigemId], references: [id], onDelete: SetNull)
  repassesGerados   TransacaoFinanceira[] @relation("RepasseOrigem")

  // Integration Fields
  interNossoNumero       String?   @unique
  interPixCode           String? // PIX Copy & Paste string
  interBarcode           String? // Boleto Barcode
  interPdfKey            String? // File name/key in RustFS/MinIO
  interStatus            String? // Inter's status: APROVADO, PAGO, VENCIDO, etc.
  interCodigoSolicitacao String?   @unique
  interSeuNumero         String?   @unique
  interTxId              String?
  interOrigemRecebimento String?
  interDataRecebimento   DateTime?
  interValorRecebido     Decimal?  @db.Decimal(15, 2) // para confronto

  @@map("transacao_financeira")
}

model InterWebhookEvent {
  id                 String                  @id @default(uuid())
  eventKey           String                  @unique
  codigoSolicitacao  String?
  nossoNumero        String?
  seuNumero          String?
  contaCorrente      String?
  situacao           String
  origemRecebimento  String?
  valorTotalRecebido Decimal?                @db.Decimal(15, 2)
  dataHoraSituacao   DateTime?
  payload            Json
  status             InterWebhookEventStatus
  tentativas         Int                     @default(0)
  erro               String?
  recebidoEm         DateTime                @default(now())
  processadoEm       DateTime?

  @@index([codigoSolicitacao])
  @@index([nossoNumero])
  @@index([status, recebidoEm])
  @@map("inter_webhook_event")
}

enum InterWebhookEventStatus {
  RECEBIDO
  PROCESSANDO
  PROCESSADO
  IGNORADO
  ERRO
}

model ConfiguracaoInter {
  id           String   @id @default(uuid())
  imobId       String   @unique
  imob         Imob     @relation(fields: [imobId], references: [id], onDelete: Cascade)
  clientId     String
  clientSecret String
  certPem      String   @db.Text
  keyPem       String   @db.Text
  sandbox      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("configuracao_inter")
}

enum TipoNegocioComissao {
  VENDA
  LOCACAO
}

enum StatusComissao {
  PENDENTE
  PAGO
}

model Comissao {
  id                String              @id @default(uuid())
  usuarioId         String
  usuario           Users               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  valorBrutoNegocio Float
  percentual        Float
  valorComissao     Float
  tipoNegocio       TipoNegocioComissao
  referenciaId      String? // ID do Imovel ou Contrato
  dataVencimento    DateTime
  status            StatusComissao      @default(PENDENTE)
  dataPagamento     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  transacaoId String?
  transacao   TransacaoFinanceira? @relation(fields: [transacaoId], references: [id], onDelete: SetNull)

  @@map("comissao")
}

enum StatusMovimentacaoBancaria {
  PENDENTE
  CONCILIADO
}

enum TipoMovimentacaoBancaria {
  CREDITO
  DEBITO
}

model MovimentacaoBancaria {
  id        String                     @id @default(uuid())
  data      DateTime
  descricao String
  valor     Float
  tipo      TipoMovimentacaoBancaria
  fitid     String?                    @unique // Identificador único da transação bancária (evitar duplicados)
  status    StatusMovimentacaoBancaria @default(PENDENTE)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  transacaoId String?
  transacao   TransacaoFinanceira? @relation(fields: [transacaoId], references: [id], onDelete: SetNull)

  @@map("movimentacao_bancaria")
}
